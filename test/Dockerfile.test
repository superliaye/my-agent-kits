FROM node:20-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates curl bash \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI (used by the plugin primitive — `claude plugin install`)
RUN npm install -g @anthropic-ai/claude-code --no-audit --no-fund --silent \
    && which claude && claude --version

WORKDIR /kit
COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY . .

# Make the launcher and test scripts executable. Test cases invoke
# /kit/bin/agent-kit directly via $KIT_ROOT — no PATH shim, matching the
# install flow documented in README.md.
RUN chmod +x /kit/bin/agent-kit /kit/bootstrap.sh /kit/test/run-tests.sh /kit/test/cases/*.sh /kit/test/lib/assertions.sh

# Configure git (test cases `git init` inside their tmpdirs)
RUN git config --global user.email "test@example.com" \
    && git config --global user.name "Test User"

CMD ["bash", "/kit/test/run-tests.sh"]

FROM node:20-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates curl bash python3 python3-pip python3-venv pipx \
    && rm -rf /var/lib/apt/lists/*

# Install APM CLI from source via pipx (most reliable on Linux containers)
RUN pipx install --pip-args='--no-cache-dir' "git+https://github.com/microsoft/apm.git" \
    && ln -sf /root/.local/bin/apm /usr/local/bin/apm \
    && which apm && apm --version

WORKDIR /kit
COPY package.json package-lock.json* ./
RUN npm install --no-audit --no-fund
COPY . .

# Bootstrap (link agent-kit into /usr/local/bin)
RUN chmod +x /kit/bin/agent-kit /kit/bootstrap.sh /kit/test/run-tests.sh /kit/test/cases/*.sh /kit/test/lib/assertions.sh \
    && ln -sf /kit/bin/agent-kit /usr/local/bin/agent-kit

# Configure git for APM (it inspects git config when installing packages)
RUN git config --global user.email "test@example.com" \
    && git config --global user.name "Test User"

# Tests install the kit from a local path (avoids needing GitHub auth for a private repo)
ENV AGENT_KIT_REF=/kit

CMD ["bash", "/kit/test/run-tests.sh"]
